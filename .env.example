# Stodi configuration — copy to .env and fill in. See DEPLOY.md for details.

# Gemini access: either an API key…
GOOGLE_API_KEY=your-gemini-api-key
# …or Vertex AI (preferred for the challenge stack)
GOOGLE_CLOUD_PROJECT=your-gcp-project
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_GENAI_USE_VERTEXAI=true

# Model
STODI_MODEL=gemini-2.5-flash

# Persistence: json | firestore | memory
STODI_STORE=json

# Vertex AI Search grounding — set to activate RAG over the exam-pack corpus
# VERTEX_SEARCH_DATASTORE=projects/<p>/locations/<l>/collections/default_collection/dataStores/<id>

# Drip quizzes
STODI_DRIP_DRY_RUN=true
STODI_DRIP_INTERVAL_MINUTES=60

# Telegram channel
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# API gate — when set, /chat /switch /progress /drip require X-API-Key.
# Generate one: openssl rand -hex 16
# STODI_API_KEY=
